# Desktop shell stays shell-only, points at the shared Web workbench,
# and does not imply a native business client or desktop-owned template system.
TRACEFOLD_DESKTOP_WEB_WORKBENCH_URL=http://127.0.0.1:3000/workbench
TRACEFOLD_DESKTOP_API_BASE_URL=http://127.0.0.1:8000/api
# Allowed values today: window, tray
TRACEFOLD_DESKTOP_STARTUP_MODE=window
TRACEFOLD_DESKTOP_DEBUG=false
TRACEFOLD_DESKTOP_LOG_ENABLED=true
