# Telegram stays adapter-only, uses the shared API base URL,
# and does not imply template CRUD, workbench modes, or a management-client role.
TRACEFOLD_TELEGRAM_BOT_TOKEN=replace-me
TRACEFOLD_TELEGRAM_API_BASE_URL=http://127.0.0.1:8000/api
TRACEFOLD_TELEGRAM_TIMEOUT_SECONDS=5
TRACEFOLD_TELEGRAM_DEBUG=false
TRACEFOLD_TELEGRAM_LOG_ENABLED=true
